@model StudentManagementSystem.Models.Student

<div class="row justify-content-center">

    <div class="col-md-8">

        <div class="card">

            <div class="card-body">

                <h3 class="mb-4">

                    <i class="bi bi-person-plus-fill"></i>

                    Add Student

                </h3>

                <form asp-action="Create" method="post">

                <div class="mb-3">

                        <label asp-for="Name"
                               class="form-label fw-bold"></label>

                        <input asp-for="Name" class="form-control" />

                        <span asp-validation-for="Name" class="text-danger"></span>

                </div>

                <div class="mb-3">

                        <label asp-for="Age"
                               class="form-label fw-bold"></label>

                        <input asp-for="Age" class="form-control" type="number" min="18" max="70"/>

                        <span asp-validation-for="Age" class="text-danger"></span>
                
                </div>

                <div class="mb-3">

                        <label asp-for="Course"
                               class="form-label fw-bold"></label>

                        <input asp-for="Course" class="form-control" />

                        <span asp-validation-for="Course" class="text-danger"></span>

                </div>

                    <div class="mt-4">

                        <button class="btn btn-primary">

                            <i class="bi bi-check-circle"></i>

                            Save

                        </button>

                        <a asp-controller="Student" asp-action="Index"
                           class="btn btn-secondary ms-2">

                            <i class="bi bi-arrow-left"></i>

                            Cancel

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>