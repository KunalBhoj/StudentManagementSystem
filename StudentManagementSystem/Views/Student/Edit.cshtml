@model StudentManagementSystem.Models.Student

<h2>Edit Student</h2>

<form asp-action="Edit" method="post">

    <input asp-for="Id" type="hidden" />

    <div class="mb-3">

        <label>Name</label>

        <input asp-for="Name" class="form-control" />

        <span asp-validation-for="Name" class="text-danger"></span>

    </div>

    <div class="mb-3">

        <label>Age</label>

        <input asp-for="Age" class="form-control" type="number" min="18" max="70"/>

        <span asp-validation-for="Age" class="text-danger"></span>

    </div>

    <div class="mb-3">

        <label>Course</label>

        <input asp-for="Course" class="form-control" />

        <span asp-validation-for="Course" class="text-danger"></span>

    </div>

    <button class="btn btn-primary">

        Update

    </button>

    <a asp-controller="Student" asp-action="Index" class="btn btn-secondary">
        
        Cancel
    
    </a>

</form>